{
  "plugins": ["prettier-plugin-toml"],
  "overrides": [
    {
      "files": ["**/*.md"],
      "options": {
        "proseWrap": "preserve"
      }
    },
    {
      "files": ["**/*.yml", "**/*.yaml"],
      "options": {}
    },
    {
      "files": ["**/*.toml"],
      "options": {
        "parser": "toml"
      }
    }
  ]
}
